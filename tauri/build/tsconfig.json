{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"experimentalDecorators": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["vite/client", "node"]
	},
	"include": [
		"vite.config.ts",
		"entrypoints.ts",
		"plugins/*.ts"
	]
}
